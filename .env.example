# Required: Turso database
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Optional but recommended: AI assistant/RAG
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gemma-4-31b

# Optional but recommended: Midtrans online payment gateway
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_MODE=sandbox
MIDTRANS_BASE_URL=https://api.sandbox.midtrans.com
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# Required: Auth/admin
NEXTAUTH_SECRET=generate_a_long_random_secret_for_production
CUSTOMER_SESSION_SECRET=generate_a_separate_random_secret_for_customer_cookie
NEXTAUTH_URL=https://your-vercel-domain.vercel.app
AUTH_URL=https://your-vercel-domain.vercel.app
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_ROLE_MAP=

# Required: Cron endpoints security
CRON_SECRET=generate_a_long_random_cron_secret

# Required: Cloudinary upload/storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional: Telegram integration
TELEGRAM_BOT_TOKEN=

# Optional: OCR provider for payment proof assistance
# OCR_MODE can be off, manual, or conditional. Recommended MVP: conditional.
OCR_MODE=conditional
GEMINI_VISION_MODEL=gemini-2.0-flash
PAYMENT_OCR_ENDPOINT=
PAYMENT_OCR_API_KEY=
